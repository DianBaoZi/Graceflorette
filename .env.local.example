# ─────────────────────────────────────────────────────────────────────────────
# Grace's Florette — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase Project URL (safe to expose — needed by client + server)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon (public) key (safe to expose — RLS enforces access control)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─────────────────────────────────────────────────────────────────────────────
# NEVER add SUPABASE_SERVICE_ROLE_KEY here.
# The service role key bypasses all RLS policies.
# It is only needed for local seeding scripts and must never be deployed.
# ─────────────────────────────────────────────────────────────────────────────
